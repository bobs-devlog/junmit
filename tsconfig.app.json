{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    "strict": true,
    "noFallthroughCasesInSwitch": true,
    // noUnusedLocals/noUnusedParametersлҠ” ESLint(no-unused-vars)мҷҖ мӨ‘ліөмқҙлқј ESLintм—җ мң„мһ„
    // verbatimModuleSyntaxлҠ” type-only importлҘј к°•м ңн•ҙ мҙҲкё° ліҖнҷҳ л¶ҖлӢҙмқ„ нӮӨмҡ°лҜҖлЎң лҒ”

    "useDefineForClassFields": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
